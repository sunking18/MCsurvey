# 问卷后端配置示例
# 复制为 backend/.env 并填入真实值（.env 已被 gitignore 忽略，切勿提交密钥）
# 或在启动前 export 这些变量。

# 数据导出密钥（管理员在 /admin.html 输入）
EXPORT_KEY=admin123

# 服务端口
PORT=3000

# ===== 微信公众号网页授权（可选）=====
# 配置后「微信内自动识别 / 再看报告」能力启用；留空则纯匿名采集。
# 在公众号后台「设置与开发 → 基本配置」获取 AppID 和 AppSecret。
# 前置：公众号需配置「网页授权域名」（部署域名，已备案 + HTTPS），
#       并把微信下发的校验文件放到网站根目录可访问。
MP_APPID=
MP_SECRET=

# 可选：强制回调地址根域名。部署在 Nginx(HTTPS) 后若后端自动识别到的
# 协议/host 不正确（例如拿到 http 而非 https），可设为你的站点根，例如：
# PUBLIC_BASE_URL=https://survey.yourdomain.com
# 留空则按请求头自动推导（需 Nginx 正确传递 X-Forwarded-Proto / X-Forwarded-Host）。
PUBLIC_BASE_URL=
